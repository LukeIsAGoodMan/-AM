{
  "name": "am",
  "version": "0.0.1",
  "private": true,
  "description": "HK Card Rewards (Ask Mike) - foundation layer",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "validate:data": "tsx scripts/validate-data.ts",
    "import:data": "tsx --env-file=.env.local scripts/import-data.ts",
    "extract:sources": "tsx --env-file=.env.local scripts/extract-sources.ts",
    "diagnose": "tsx --env-file=.env.local scripts/diagnose.ts",
    "verify:ui": "tsx scripts/inspect-calc-page.ts",
    "fetch:card-images": "tsx --env-file=.env.local scripts/fetch-card-images.ts",
    "p2:dry-run": "tsx --env-file=.env.local scripts/p2-dry-run.ts",
    "p3:run": "tsx --env-file=.env.local scripts/p3-run-extraction.ts",
    "p4:aggregate": "tsx --env-file=.env.local scripts/p4-aggregate.ts",
    "p7:materialize": "tsx --env-file=.env.local scripts/p7-materialize.ts",
    "db:seed": "pnpm import:data"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@tanstack/react-table": "^8.21.3",
